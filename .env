# MySQL (приложение IrTRAN)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=irtran
MYSQL_USER=irtran
MYSQL_PASSWORD=irtran

# Keycloak: реалм, который использует приложение (должен существовать в Keycloak)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KEYCLOAK_REALM=master
KEYCLOAK_RESOURCE=irtran-client

KC_HOSTNAME=app.otred.ru
# Публичный URL Keycloak для бэкенда (issuer в токене) — должен совпадать со схемой, по которой заходит браузер (у вас только HTTP на :80)
KEYCLOAK_AUTH_SERVER_URL=http://app.otred.ru/auth

VITE_KEYCLOAK_URL=http://app.otred.ru/auth
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_RESOURCE=irtran-client
VITE_API_URL=http://app.otred.ru 